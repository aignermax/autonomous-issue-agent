# GitHub Authentication
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Target Repositories
# Multi-repo mode: Use AGENT_REPOS for multiple repositories (comma-separated)
AGENT_REPOS=owner/repo1,owner/repo2,owner/repo3

# Single-repo mode: Use AGENT_REPO for a single repository (ignored if AGENT_REPOS is set)
# AGENT_REPO=aignermax/Connect-A-PIC-Pro

# Optional Configuration
AGENT_POLL_INTERVAL=15                 # Agent polling interval in seconds (default: 15)
DASHBOARD_REFRESH_INTERVAL=5           # Dashboard refresh interval in seconds (default: 5)
AGENT_ISSUE_LABEL=agent-task           # Activation label - issues must have this to be picked up (default: agent-task)
AGENT_COMPLEXITY_TAG=complex           # Complexity modifier - presence of this tag activates higher limits (default: complex)
AGENT_REPO_PATH=./repo                 # Local path for repository clone (default: ./repo)

# Resource limits based on complexity
# Regular tasks (agent-task only): Simple fixes, docs, small features
AGENT_MAX_TURNS_REGULAR=150            # Max turns for regular issues (default: 150)
AGENT_MAX_TOKENS_REGULAR=8000000       # Max tokens for regular issues: 8M ≈ €24-40

# Complex tasks (agent-task + complex tag): Full features, refactoring, architecture
AGENT_MAX_TURNS_COMPLEX=500            # Max turns for complex issues (default: 500)
AGENT_MAX_TOKENS_COMPLEX=15000000      # Max tokens for complex issues: 15M ≈ €45-75

# Stacked PRs - PRs build on each other instead of all on main
# When enabled: PR #2 bases on branch from PR #1, PR #3 on PR #2, etc.
# When disabled: All PRs base on main (independent)
AGENT_ENABLE_STACKED_PRS=false         # Enable stacked PRs (default: false)

# Setup Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual tokens and configuration
# 3. Never commit .env to version control (already in .gitignore)

# ==============================
# WORKTREES & REVIEWER (multi-role agent)
# ==============================

# Base directory for per-issue git worktrees
AGENT_WORKTREE_DIR=~/.aia-worktrees

# Reviewer settings
AGENT_MAX_REVIEW_ROUNDS=2              # Worker → Reviewer iterations before escalation
AGENT_REVIEWER_MODEL=claude-sonnet-4-6 # Default reviewer model
AGENT_REVIEWER_MODEL_CRITICAL=claude-opus-4-7  # Used when issue has 'critical' label
AGENT_CRITICAL_LABEL=critical          # Label that triggers the higher-tier reviewer
AGENT_REVIEWER_MAX_TURNS=50            # Max turns for one review pass

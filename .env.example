# GitHub Authentication
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Target Repositories
# Multi-repo mode: Use AGENT_REPOS for multiple repositories (comma-separated)
AGENT_REPOS=owner/repo1,owner/repo2,owner/repo3

# Single-repo mode: Use AGENT_REPO for a single repository (ignored if AGENT_REPOS is set)
# AGENT_REPO=aignermax/Connect-A-PIC-Pro

# Optional Configuration
AGENT_POLL_INTERVAL=15                 # Polling interval in seconds (default: 15)
AGENT_ISSUE_LABEL=agent-task           # Label to identify issues for the agent (default: agent-task)
AGENT_MAX_TURNS=500                    # Maximum Claude Code turns per issue (default: 300, allows complex features)
AGENT_REPO_PATH=./repo                 # Local path for repository clone (default: ./repo)

# Stacked PRs - PRs build on each other instead of all on main
# When enabled: PR #2 bases on branch from PR #1, PR #3 on PR #2, etc.
# When disabled: All PRs base on main (independent)
AGENT_ENABLE_STACKED_PRS=false         # Enable stacked PRs (default: false)

# Setup Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual tokens and configuration
# 3. Never commit .env to version control (already in .gitignore)
